 if operations should be blocked\"}},\"notice\":\"Drosera response contract for Safe{Wallet} multisig protection.         When the BybitSafeTrap detects any compromise vector, Drosera         operators call this contract to trigger an emergency response.\",\"version\":1}},\"settings\":{\"compilationTarget\":{\"src/SafeGuardResponder.sol\":\"SafeGuardResponder\"},\"evmVersion\":\"prague\",\"libraries\":{},\"metadata\":{\"bytecodeHash\":\"ipfs\"},\"optimizer\":{\"enabled\":false,\"runs\":200},\"remappings\":[\":drosera-contracts/=node_modules/drosera-contracts/src/\",\":forge-std/=node_modules/forge-std/src/\"]},\"sources\":{\"src/SafeGuardResponder.sol\":{\"keccak256\":\"0x5b21ad96ca90213701bc8ef632b9c7570cf0d45bdd4af0612721a7a464ecbadf\",\"license\":\"MIT\",\"urls\":[\"bzz-raw://3747a8542186e5ddf96da5cbac45a6558c41a3de93fdb75b7fd380f489edb30d\",\"dweb:/ipfs/QmcmxZ3pEoEC8GVeT87Z2ZAW5bVfBWAHWj528Y121L53vr\"]}},\"version\":1}","metadata":{"compiler":{"version":"0.8.33+commit.64118f21"},"language":"Solidity","output":{"abi":[{"inputs":[{"internalType":"address","name":"_droseraOperator","type":"address"}],"stateMutability":"nonpayable","type":"constructor"},{"inputs":[{"internalType":"address","name":"triggeredBy","type":"address","indexed":true},{"internalType":"uint256","name":"blockNumber","type":"uint256","indexed":false},{"internalType":"address","name":"reportedImplementation","type":"address","indexed":false},{"internalType":"address","name":"expectedImplementation","type":"address","indexed":false},{"internalType":"uint8","name":"threatType","type":"uint8","indexed":false}],"type":"event","name":"EmergencyPauseTriggered","anonymous":false},{"inputs":[{"internalType":"address","name":"triggeredBy","type":"address","indexed":true},{"internalType":"uint256","name":"blockNumber","type":"uint256","indexed":false}],"type":"event","name":"EmergencyUnpaused","anonymous":false},{"inputs":[],"stateMutability":"view","type":"function","name":"droseraOperator","outputs":[{"